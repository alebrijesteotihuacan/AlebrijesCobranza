# Supabase (público — seguro exponerlo con NEXT_PUBLIC_)
# Obtener en: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project_ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_public_key>

# App
NEXT_PUBLIC_APP_NAME="Alebrijes Cobranza"
NEXT_PUBLIC_PAYMENT_INFO="Banco · CLABE · Tarjeta · Transferencia a nombre de Club Alebrijes Oaxaca"

# ============================================================
# Secretos de Edge Functions (NO se ponen en .env.local)
# Se configuran con: supabase secrets set KEY=VALUE
# ============================================================
#
# WHATSAPP_TOKEN=<system_user_access_token>
# WHATSAPP_PHONE_NUMBER_ID=<phone_id>
# WHATSAPP_BUSINESS_ACCOUNT_ID=<waba_id>
# WHATSAPP_APP_SECRET=<app_secret>
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=<custom_verify_token>
# SUPABASE_URL=https://<project_ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
